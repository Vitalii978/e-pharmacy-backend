{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Pharmacy Admin API",
    "version": "1.0.0",
    "description": "API для админ-панели магазина лекарств"
  },
  "servers": [
    { "url": "http://localhost:3000/api" },
    { "url": "https://e-pharmacy-backend-0kth.onrender.com" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "token": { "type": "string" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "price": { "type": "string" },
          "stock": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "Medicine",
              "Head",
              "Hand",
              "Dental Care",
              "Skin Care",
              "Eye Care",
              "Vitamins & Supplements",
              "Leg",
              "Baby Care",
              "Heart"
            ]
          },
          "suppliers": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "products": { "type": "string" },
          "price": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "Confirmed",
              "Shipped",
              "Delivered",
              "Completed",
              "Processing",
              "Cancelled",
              "Pending"
            ]
          },
          "order_date": { "type": "string" }
        }
      },
      "Supplier": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "suppliers": { "type": "string" },
          "date": { "type": "string" },
          "amount": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["Active", "Deactive"]
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "spent": { "type": "string" },
          "address": { "type": "string" },
          "register_date": { "type": "string" }
        }
      },
      "Dashboard": {
        "type": "object",
        "properties": {
          "customers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Customer" }
          },
          "dashboard": { "type": "array", "items": { "type": "object" } },
          "customersCount": { "type": "number" },
          "productsCount": { "type": "number" },
          "suppliersCount": { "type": "number" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/user/register": {
      "post": {
        "tags": ["User"],
        "summary": "Регистрация нового пользователя",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Test User" },
                  "email": { "type": "string", "example": "test@test.com" },
                  "password": { "type": "string", "example": "12345678" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Успешная регистрация",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "email": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Email уже используется",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["User"],
        "summary": "Вход в систему",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "test@test.com" },
                  "password": { "type": "string", "example": "12345678" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешный вход",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": {
            "description": "Неверный email или пароль",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/user/user-info": {
      "get": {
        "tags": ["User"],
        "summary": "Получить информацию о текущем пользователе",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Информация о пользователе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": { "type": "string" },
                    "email": { "type": "string" },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/user/logout": {
      "get": {
        "tags": ["User"],
        "summary": "Выход из системы",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешный выход",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Получить все продукты (с фильтром по названию)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Фильтр по названию (необязательный)"
          }
        ],
        "responses": {
          "200": {
            "description": "Список продуктов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    },
                    "categories": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Создать новый продукт",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "price", "stock", "category", "suppliers"],
                "properties": {
                  "name": { "type": "string", "example": "Aspirin" },
                  "price": { "type": "string", "example": "$10.99" },
                  "stock": { "type": "string", "example": "150" },
                  "category": { "type": "string", "example": "Medicine" },
                  "suppliers": { "type": "string", "example": "PharmaInc" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Продукт создан",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "400": { "description": "Продукт с таким именем уже существует" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/products/{_id}": {
      "put": {
        "tags": ["Products"],
        "summary": "Обновить продукт",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": "string" },
                  "stock": { "type": "string" },
                  "category": { "type": "string" },
                  "suppliers": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Продукт обновлен" },
          "404": { "description": "Продукт не найден" },
          "401": { "description": "Не авторизован" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Удалить продукт",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Продукт удален" },
          "404": { "description": "Продукт не найден" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Получить все заказы (с фильтром по имени)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Фильтр по имени клиента"
          }
        ],
        "responses": {
          "200": {
            "description": "Список заказов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Order" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Создать новый заказ",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "address",
                  "products",
                  "price",
                  "order_date"
                ],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "address": { "type": "string", "example": "123 Main St" },
                  "products": { "type": "string", "example": "Aspirin x2" },
                  "price": { "type": "string", "example": "$125.99" },
                  "status": { "type": "string", "example": "Pending" },
                  "order_date": {
                    "type": "string",
                    "example": "March 10, 2024"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Заказ создан" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/orders/{_id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Получить заказ по ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Заказ найден" },
          "404": { "description": "Заказ не найден" },
          "401": { "description": "Не авторизован" }
        }
      },
      "put": {
        "tags": ["Orders"],
        "summary": "Обновить заказ",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" },
                  "address": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Заказ обновлен" },
          "404": { "description": "Заказ не найден" },
          "401": { "description": "Не авторизован" }
        }
      },
      "delete": {
        "tags": ["Orders"],
        "summary": "Удалить заказ",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Заказ удален" },
          "404": { "description": "Заказ не найден" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/suppliers": {
      "get": {
        "tags": ["Suppliers"],
        "summary": "Получить всех поставщиков (с фильтром)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Список поставщиков",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Supplier" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "tags": ["Suppliers"],
        "summary": "Добавить поставщика",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "address", "suppliers", "date", "amount"],
                "properties": {
                  "name": { "type": "string", "example": "MedSupply Co." },
                  "address": {
                    "type": "string",
                    "example": "456 Healthcare Ave"
                  },
                  "suppliers": { "type": "string", "example": "PharmaCorp" },
                  "date": { "type": "string", "example": "March 15, 2024" },
                  "amount": { "type": "string", "example": "$5,000" },
                  "status": { "type": "string", "example": "Active" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Поставщик добавлен" },
          "400": { "description": "Поставщик с таким именем уже существует" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/suppliers/{_id}": {
      "put": {
        "tags": ["Suppliers"],
        "summary": "Обновить поставщика",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Поставщик обновлен" },
          "404": { "description": "Поставщик не найден" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/customers": {
      "get": {
        "tags": ["Customers"],
        "summary": "Получить всех клиентов (с фильтром)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Список клиентов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Customer" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "tags": ["Customers"],
        "summary": "Создать нового клиента",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "email",
                  "phone",
                  "spent",
                  "address",
                  "register_date"
                ],
                "properties": {
                  "name": { "type": "string", "example": "John Smith" },
                  "email": { "type": "string", "example": "john@email.com" },
                  "phone": { "type": "string", "example": "+1 234 567 890" },
                  "spent": { "type": "string", "example": "$1,250" },
                  "address": { "type": "string", "example": "789 Oak Street" },
                  "register_date": {
                    "type": "string",
                    "example": "March 10, 2024"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Клиент создан" },
          "409": { "description": "Email уже используется" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/customers/{_id}": {
      "get": {
        "tags": ["Customers"],
        "summary": "Получить клиента по ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Клиент найден" },
          "404": { "description": "Клиент не найден" },
          "401": { "description": "Не авторизован" }
        }
      },
      "put": {
        "tags": ["Customers"],
        "summary": "Обновить клиента",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "spent": { "type": "string" },
                  "phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Клиент обновлен" },
          "404": { "description": "Клиент не найден" },
          "401": { "description": "Не авторизован" }
        }
      },
      "delete": {
        "tags": ["Customers"],
        "summary": "Удалить клиента",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Клиент удален" },
          "404": { "description": "Клиент не найден" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Получить статистику для главной страницы",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Статистика",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Dashboard" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    }
  },
  "tags": [
    { "name": "User", "description": "Авторизация и пользователи" },
    { "name": "Products", "description": "Управление продуктами" },
    { "name": "Orders", "description": "Управление заказами" },
    { "name": "Suppliers", "description": "Управление поставщиками" },
    { "name": "Customers", "description": "Управление клиентами" },
    { "name": "Dashboard", "description": "Статистика" }
  ]
}
